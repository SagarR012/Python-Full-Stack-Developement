    },
    {
      "name": "Loans",
      "description": "Book loan management. Members can borrow/return books. Staff sees all loans.",
      "item": [
        {
          "name": "Borrow a Book (Create Loan)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/loans/", "host": ["{{base_url}}"], "path": ["api", "v1", "loans", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"book\": 1,\n  \"notes\": \"Borrowing for a book club.\"\n}"
            },
            "description": "Borrow a book. Requires authentication.\n\nThe API automatically:\n- Sets the borrower to the current user\n- Calculates due_date as today + 14 days\n- Decrements the book's available_copies\n- Prevents borrowing if no copies are available\n- Prevents borrowing the same book twice"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 or 400 (no copies available)', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 400]);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    // Save loan ID for return test",
                  "    pm.environment.set('loan_id', json.id);",
                  "    console.log('Loan created with ID:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "My Loans",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/loans/my-loans/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "loans", "my-loans", ""],
              "query": [
                { "key": "status", "value": "active", "disabled": true }
              ]
            },
            "description": "List the current user's loans.\n\nThis custom action always returns only the current user's loans,\neven if they are staff (unlike the main list endpoint).\n\nOptional query param: `?status=active|returned|overdue`"
          }
        },
        {
          "name": "Return a Book",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/loans/{{loan_id}}/return/", "host": ["{{base_url}}"], "path": ["api", "v1", "loans", "{{loan_id}}", "return", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Returned in good condition.\"\n}"
            },
            "description": "Return a borrowed book. Requires authentication.\n\nThe API automatically:\n- Sets return_date to now\n- Changes status to 'returned'\n- Increments the book's available_copies\n\nOnly the borrower (or staff) can process a return."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK or 400 already returned', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    pm.test('Loan status is returned', function() {",
                  "        const json = pm.response.json();",
                  "        pm.expect(json.status).to.eql('returned');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "All Loans (Staff/Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/loans/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "loans", ""],
              "query": [
                { "key": "ordering", "value": "-loan_date", "disabled": true }
              ]
            },
            "description": "List all loans (returns only the current user's loans for non-staff users).\n\nFor staff/admin: returns ALL loans in the system.\nFor regular members: returns only their own loans."
          }
        },
        {
          "name": "Get Loan Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/loans/{{loan_id}}/", "host": ["{{base_url}}"], "path": ["api", "v1", "loans", "{{loan_id}}", ""] }
          }
        }
      ]
    },
    {
      "name": "API Documentation",
      "description": "Endpoints for exploring the API documentation.",
      "item": [
        {
